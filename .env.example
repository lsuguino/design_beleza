# Copie este arquivo para .env.local e preencha as chaves.
# No Windows: copy .env.example .env.local

# Obrigatório: geração de conteúdo e design (Anthropic Claude)
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sua-chave-aqui

# Opcional: geração de imagens no material (DALL-E 3)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
