# OpenRouter — texto/LLM (obrigatório para geração de conteúdo e design)
# Chave: https://openrouter.ai/keys
OPENROUTER_API_KEY=sua-chave-aqui
# Slug do modelo (ex.: anthropic/claude-3.5-sonnet, openai/gpt-4o). Lista: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Opcional (recomendado pelo OpenRouter)
# OPENROUTER_HTTP_REFERER=https://seu-dominio.com
# OPENROUTER_X_TITLE=design-beleza

# Opcional: imagens no material (Hugging Face ou OpenAI)
# HUGGINGFACE_HUB_TOKEN=
# OPENAI_API_KEY=
